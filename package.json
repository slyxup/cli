{
  "name": "slyxup",
  "version": "1.0.0",
  "description": "Fast, secure CLI for modern project scaffolding. Create React, Vue, Next.js, Express, NestJS projects in seconds. The modern alternative to create-react-app with SHA-256 verified templates and automatic rollback.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "slyxup": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "deploy": "node scripts/deploy.js",
    "deploy:local": "node scripts/deploy.js local",
    "deploy:prod": "node scripts/deploy.js prod"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "project-generator",
    "react",
    "react-template",
    "create-react-app",
    "create-react-app-alternative",
    "vue",
    "vue-template",
    "nextjs",
    "next-template",
    "nuxt",
    "svelte",
    "astro",
    "express",
    "express-template",
    "nestjs",
    "nest-template",
    "remix",
    "hono",
    "vite",
    "vite-template",
    "typescript",
    "typescript-starter",
    "boilerplate",
    "starter-kit",
    "starter-template",
    "project-template",
    "generator",
    "frontend",
    "backend",
    "fullstack",
    "full-stack",
    "tailwind",
    "tailwindcss",
    "shadcn",
    "shadcn-ui",
    "prisma",
    "drizzle",
    "secure",
    "sha256",
    "developer-tools",
    "dev-tools",
    "productivity",
    "npm-cli",
    "node-cli",
    "web-development",
    "app-generator",
    "project-scaffolding",
    "code-generator",
    "template-engine",
    "discord-bot",
    "graphql"
  ],
  "author": "SlyxUp Team",
  "license": "MIT",
  "homepage": "https://slyxup.online",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slyxup/cli.git"
  },
  "bugs": {
    "url": "https://github.com/slyxup/cli/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/slyxup"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.15",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "tar": "^7.0.1",
    "zod": "^3.22.4",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.20",
    "@types/tar": "^6.1.11",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}